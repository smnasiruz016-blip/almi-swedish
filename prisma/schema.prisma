// AlmiGoethe data model. The shared engine foundation (auth, billing, AI cost
// ledger) is forked from AlmiCELPIP. The practice layer is an ITEM-BANK: a single
// GoetheItem ↔ GoetheAttempt pair carries every task type via a typed `payload`
// Json, instead of one model per skill. Scoring is hybrid — deterministic for
// objective modules (Lesen + Hören), AI trait-feedback for productive modules
// (Schreiben + Sprechen) — and is reported as an honest practice POINTS estimate
// per module (max points + 60% pass threshold), never a fabricated total.
//
// The big structural fact vs CELPIP: CELPIP's GENERAL/LS version axis is replaced
// by SIX CEFR LEVELS (A1–C2), and — unlike CELPIP where the version lived only on
// the session — a Goethe item belongs to exactly ONE level (A1 Lesen content is
// not B2 Lesen content), so `level` lives ON THE ITEM and is the primary filter.
// All content is original German, never copied from the Goethe-Institut; results
// are practice estimates — candidates confirm the real requirement with the
// Goethe-Institut / their university / the relevant German authority.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Locale {
  EN
  UR
  AR
  HI
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  passwordHash String
  locale       Locale  @default(EN)
  countryCode  String?
  referralCode String  @unique @default(cuid())

  // Email verification — required before paid feature access.
  emailVerified               DateTime?
  emailVerificationTokenHash  String?   @unique
  emailVerificationExpiresAt  DateTime?
  emailVerificationLastSentAt DateTime?

  // Stripe subscription state — webhook keeps this in lockstep with Stripe.
  stripeCustomerId              String?          @unique
  stripeSubscriptionId          String?          @unique
  subscriptionStatus            String?
  subscriptionPlan              String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean          @default(false)
  trialEndsAt                   DateTime?
  subscriptionTier              SubscriptionTier @default(FREE)

  // Comp Pro access — admin-granted, no Stripe. isProActive()/hasPaidAccess()
  // short-circuit true while compProUntil is in the future, bypassing BOTH the
  // subscription check AND email verification. AlmiGoethe full Pro = AI feedback
  // on Schreiben + Sprechen + the full per-level mock.
  compProUntil  DateTime?
  compGrantedAt DateTime?
  compGrantedBy String?
  compReason    String?

  // Which Norwegian exam the user is preparing for (Norskprøven / Bergenstesten / knowledge tests).
  // Drives the default mock and which practice content is surfaced. Null = not chosen.
  targetExam NorwegianExam?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  daAttempts          NorwegianAttempt[]
  daSessions          NorwegianSession[]
  reviews             Review[]

  @@index([email])
  @@index([referralCode])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compProUntil])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProcessedWebhook {
  id          String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  text      String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approved, createdAt])
}

model AICostLedger {
  id               String   @id @default(cuid())
  timestamp        DateTime @default(now())
  userId           String?
  feature          String
  model            String
  inputTokens      Int
  outputTokens     Int
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costCents        Int
  success          Boolean  @default(true)
  errorMessage     String?

  @@index([timestamp(sort: Desc)])
  @@index([userId, timestamp])
  @@index([feature, timestamp])
}


// ===================== Norwegian practice item-bank =====================
// AlmiDanish covers FOUR goal tracks via ONE item-bank, all administered under
// the HK-dir (the Directorate for Higher Education and Skills):
//   • Norskprøven B1–B2 (the citizenship language exam) — B1–B2 across Reading,
//     Listening, Writing, Speaking. It is the language exam commonly required
//     for Norwegian citizenship, alongside the Statsborgerprøven. Scored per skill
//     as an honest readiness estimate vs the level's real criteria — never an
//     official UDI/Ministry result.
//   • Norskprøven A1–A2 (A1–A2) and Norskprøven A2–B1 (A2–B1, permanent residence).
//   • Bergenstesten — the advanced (≈C1) Norwegian exam for Norwegian-taught study.
//   • Statsborgerprøven / Samfunnskunnskapsprøven — Norwegian society knowledge tests
//     (multiple-choice), not language proficiency.
// One NorwegianItem/NorwegianAttempt pair serves every task type via a typed
// `payload` Json. All content is original; results are practice estimates —
// confirm the real residency/citizenship requirement with UDI.

enum NorwegianTrack {
  CITIZENSHIP // Norskprøven B1–B2 (B1–B2) + Statsborgerprøven
  PERMANENT_RESIDENCE // Norskprøven A2–B1 (A2–B1) + Samfunnskunnskapsprøven
  GETTING_STARTED // Norskprøven A1–A2 (A1–A2)
  UNIVERSITY // Bergenstesten (≈C1)
}

// Exam axis. The Norskprøven language ladder (NORSKPROVE_A1A2–NORSKPROVE_B1B2 + Bergenstesten) plus the
// two society knowledge tests (Statsborgerprøven / Samfunnskunnskapsprøven).
enum NorwegianExam {
  NORSKPROVE_A1A2 // Norskprøven A1–A2 — A1–A2
  NORSKPROVE_A2B1 // Norskprøven A2–B1 — A2–B1 (permanent residence)
  NORSKPROVE_B1B2 // Norskprøven B1–B2 — B1–B2 (citizenship, lead)
  BERGENSTEST // Bergenstesten — ≈C1 (university)
  STATSBORGERPROVEN // Norwegian citizenship knowledge test
  SAMFUNNSKUNNSKAP // Active-citizenship / PR knowledge test
}

enum NorwegianSkill {
  READING // Leseforståelse (objective)
  LISTENING // Lytteforståelse (objective)
  WRITING // Skriftlig framstilling (AI-graded)
  SPEAKING // Muntlig (AI-graded)
  KNOWLEDGE // Samfunnskunnskap — society knowledge MCQ (objective)
}

enum NorwegianTaskType {
  MCQ_SINGLE // objective single-answer multiple choice (Reading/Listening)
  MATCHING // objective matching
  CLOZE // objective gap-fill (option-per-gap)
  ORDERING // objective sequence
  TRUE_FALSE // objective true/false/not-stated
  WRITING_PROMPT // productive writing (criteria + char band)
  SPEAKING_PROMPT // productive speaking (criteria)
}

enum NorwegianDifficulty {
  FOUNDATION
  CORE
  STRETCH
}

enum NorwegianAttemptStatus {
  PENDING
  SCORED // objective auto-graded
  EVALUATED // productive AI-graded
  FAILED
}

enum NorwegianSessionMode {
  PRACTICE
  MOCK
}

enum NorwegianSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model NorwegianItem {
  id         String          @id @default(cuid())
  track      NorwegianTrack
  exam       NorwegianExam
  skill      NorwegianSkill
  taskType   NorwegianTaskType
  difficulty NorwegianDifficulty @default(CORE)
  title      String
  // Instruction / stem shown to the candidate (NL).
  prompt     String
  // Task-specific structure: objective → { options, passage, transcript, answerKey };
  // productive → { criteria[], charBand, stimulus }. Validated in src/lib/nl/types.
  payload    Json
  // Objective answer key (null for productive/AI tasks).
  answer     Json?
  // Objective max points for this item (0 for productive; readiness is qualitative).
  maxPoints  Int             @default(0)
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  attempts   NorwegianAttempt[]

  @@index([track, exam, skill, active])
  @@index([exam, skill])
}

model NorwegianAttempt {
  id        String             @id @default(cuid())
  userId    String
  itemId    String
  sessionId String?
  status    NorwegianAttemptStatus @default(PENDING)
  // User response: objective → selected answer(s); productive → { text } or { audioKey }.
  response  Json?
  // Objective scoring.
  points    Int?
  maxPoints Int?
  // Productive AI trait feedback: { traits[], summary, estimate }.
  aiFeedback Json?
  // Honest readout: per-skill "CLEAR"|"BORDERLINE"|"BELOW" — never an official result.
  readiness String?
  createdAt   DateTime  @default(now())
  submittedAt DateTime?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item    NorwegianItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  session NorwegianSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([itemId])
  @@index([sessionId])
}

model NorwegianSession {
  id        String             @id @default(cuid())
  userId    String
  track     NorwegianTrack
  exam      NorwegianExam
  mode      NorwegianSessionMode   @default(PRACTICE)
  status    NorwegianSessionStatus @default(IN_PROGRESS)
  // Aggregate readout: { perSkill: {skill: {points,max,readiness}}, overall }.
  aggregate Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts NorwegianAttempt[]

  @@index([userId, createdAt])
}
